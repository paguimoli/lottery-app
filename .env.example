# App runtime
NODE_ENV=production

# Supabase public client
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key

# Supabase server/admin client
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_ANON_KEY=your-supabase-anon-key

# RabbitMQ
# Use rabbitmq as the hostname inside Docker Compose, not localhost.
RABBITMQ_URL=amqp://lottery:lottery_dev_password@rabbitmq:5672
RABBITMQ_EXCHANGE_NAME=lottery.events
# Optional. Defaults to the RABBITMQ_URL host on port 15672.
RABBITMQ_MANAGEMENT_URL=http://lottery:lottery_dev_password@rabbitmq:15672

# Worker observability thresholds
WORKER_OUTBOX_WARNING_AGE_SECONDS=300
WORKER_OUTBOX_CRITICAL_AGE_SECONDS=900
WORKER_QUEUE_WARNING_READY_COUNT=100
WORKER_CRITICAL_QUEUE_CRITICAL_READY_COUNT=25
WORKER_HEARTBEAT_STALE_SECONDS=300
WORKER_INSTANCE_ID=

# Redis
# Use redis as the hostname inside Docker Compose, not localhost.
REDIS_URL=redis://redis:6379

# Authority control
# These controls are advisory/defaulted in Phase 13.9. Do not set SERVICE until
# the matching authority-transfer runbook has been executed and approved.
SETTLEMENT_AUTHORITY=MONOLITH
LEDGER_AUTHORITY=MONOLITH
CREDIT_AUTHORITY=MONOLITH
SETTLEMENT_COMPARISON_MODE=ENABLED
LEDGER_COMPARISON_MODE=ENABLED
CREDIT_COMPARISON_MODE=ENABLED
SETTLEMENT_AUTHORITY_DRY_RUN_MODE=DISABLED
SETTLEMENT_MISMATCH_ALERT_THRESHOLD=0.001
LEDGER_MISMATCH_ALERT_THRESHOLD=0.001
CREDIT_MISMATCH_ALERT_THRESHOLD=0.001
SETTLEMENT_ROLLBACK_FAILURE_THRESHOLD=0.001

# .NET template service
DOTNET_TEMPLATE_SERVICE_NAME=dotnet-template-service
DOTNET_TEMPLATE_SERVICE_ENVIRONMENT=Production

# Ledger service skeleton
LEDGER_SERVICE_NAME=ledger-service
LEDGER_SERVICE_ENVIRONMENT=Production
LEDGER_SHADOW_MODE_ENABLED=false
LEDGER_SERVICE_URL=http://ledger-service:8080
LEDGER_SHADOW_READY_MISMATCH_RATE=0.001
LEDGER_SHADOW_READY_FAILURE_RATE=0.001
LEDGER_SHADOW_BLOCKED_MISMATCH_RATE=0.01

# Credit wallet service skeleton
CREDIT_WALLET_SERVICE_NAME=credit-wallet-service
CREDIT_WALLET_SERVICE_ENVIRONMENT=Production
CREDIT_SHADOW_MODE_ENABLED=false
CREDIT_SERVICE_URL=http://credit-wallet-service:8080
CREDIT_SHADOW_READY_MISMATCH_RATE=0.001
CREDIT_SHADOW_READY_FAILURE_RATE=0.001
CREDIT_SHADOW_BLOCKED_MISMATCH_RATE=0.01

# Settlement service shadow mode
SETTLEMENT_SERVICE_NAME=settlement-service
SETTLEMENT_SERVICE_ENVIRONMENT=Production
SETTLEMENT_SHADOW_MODE_ENABLED=false
SETTLEMENT_SERVICE_URL=http://settlement-service:8080
SETTLEMENT_SHADOW_READY_MISMATCH_RATE=0.001
SETTLEMENT_SHADOW_READY_FAILURE_RATE=0.001
SETTLEMENT_SHADOW_BLOCKED_MISMATCH_RATE=0.01

# Break-glass bootstrap inputs
# Supply real values only in local/secret-managed environments.
BREAK_GLASS_1_USERNAME=breakglass1
BREAK_GLASS_1_EMAIL=breakglass1@example.com
BREAK_GLASS_1_PASSWORD=replace-with-secret
BREAK_GLASS_1_TOTP_SECRET=replace-with-secret
BREAK_GLASS_1_LABEL=primary-break-glass
BREAK_GLASS_2_USERNAME=breakglass2
BREAK_GLASS_2_EMAIL=breakglass2@example.com
BREAK_GLASS_2_PASSWORD=replace-with-secret
BREAK_GLASS_2_TOTP_SECRET=replace-with-secret
BREAK_GLASS_2_LABEL=secondary-break-glass
