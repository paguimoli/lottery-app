# App runtime
NODE_ENV=production

# Supabase public client
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key

# Supabase server/admin client
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_ANON_KEY=your-supabase-anon-key

# RabbitMQ
# Use rabbitmq as the hostname inside Docker Compose, not localhost.
RABBITMQ_URL=amqp://lottery:lottery_dev_password@rabbitmq:5672
RABBITMQ_EXCHANGE_NAME=lottery.events
# Optional. Defaults to the RABBITMQ_URL host on port 15672.
RABBITMQ_MANAGEMENT_URL=http://lottery:lottery_dev_password@rabbitmq:15672

# Redis
# Use redis as the hostname inside Docker Compose, not localhost.
REDIS_URL=redis://redis:6379

# .NET template service
DOTNET_TEMPLATE_SERVICE_NAME=dotnet-template-service
DOTNET_TEMPLATE_SERVICE_ENVIRONMENT=Production

# Ledger service skeleton
LEDGER_SERVICE_NAME=ledger-service
LEDGER_SERVICE_ENVIRONMENT=Production

# Credit wallet service skeleton
CREDIT_WALLET_SERVICE_NAME=credit-wallet-service
CREDIT_WALLET_SERVICE_ENVIRONMENT=Production

# Break-glass bootstrap inputs
# Supply real values only in local/secret-managed environments.
BREAK_GLASS_1_USERNAME=breakglass1
BREAK_GLASS_1_EMAIL=breakglass1@example.com
BREAK_GLASS_1_PASSWORD=replace-with-secret
BREAK_GLASS_1_TOTP_SECRET=replace-with-secret
BREAK_GLASS_1_LABEL=primary-break-glass
BREAK_GLASS_2_USERNAME=breakglass2
BREAK_GLASS_2_EMAIL=breakglass2@example.com
BREAK_GLASS_2_PASSWORD=replace-with-secret
BREAK_GLASS_2_TOTP_SECRET=replace-with-secret
BREAK_GLASS_2_LABEL=secondary-break-glass
